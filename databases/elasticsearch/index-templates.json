{
  "index_patterns": ["riskshield-claim-*","riskshield-policy-*","riskshield-customer-*","riskshield-provider-*"],
  "template": {
    "settings": { "number_of_shards": 6, "number_of_replicas": 2, "refresh_interval": "5s" },
    "mappings": {
      "properties": {
        "claim_number":  { "type": "keyword" },
        "policy_number": { "type": "keyword" },
        "customer_id":   { "type": "keyword" },
        "incident_date": { "type": "date" },
        "status":        { "type": "keyword" },
        "narrative":     { "type": "text", "analyzer": "english" },
        "loss_amount":   { "type": "scaled_float", "scaling_factor": 100 },
        "currency":      { "type": "keyword" },
        "fraud_score":   { "type": "float" },
        "filed_at":      { "type": "date" },
        "tags":          { "type": "keyword" }
      }
    }
  }
}
